generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CORE MODELS ====================

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  phone       String
  password    String
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  lastLoginAt DateTime?

  // Email verification
  emailVerified           Boolean   @default(false)
  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime? @db.Timestamptz(3)

  // Password reset
  resetPasswordToken  String?   @unique
  resetPasswordExpiry DateTime? @db.Timestamptz(3)

  // Relations
  notifications      Notification[]
  travelPlans        TravelPlan[]
  refreshTokens      RefreshToken[]
  profile            Profile?
  vendorApplications VendorApplication[]
  vendor             Vendor?
  vendorReviews      VendorReview[]
  vendorTeamMembers  VendorTeamMember[]

  @@map("users")
}

model Profile {
  id String @id @default(cuid())

  // Personal Information
  dateOfBirth    DateTime? @db.Timestamptz(3)
  gender         Gender?
  nationality    String?
  profilePicture String?
  bio            String?

  // Contact Information
  address          String?
  city             String?
  country          String?
  postalCode       String?
  emergencyContact Json?

  // Preferences
  language String  @default("en")
  currency String  @default("USD")
  timezone String?

  // Travel Preferences
  dietaryRestrictions  String[]
  mobilityNeeds        String[]
  accessibilityNeeds   String[]
  preferredTravelStyle TravelStyle?
  travelCompanionPref  TravelCompanion?
  interests            String[]

  // Communication Preferences
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  smsNotifications   Boolean @default(false)
  marketingEmails    Boolean @default(false)

  // Account Details
  twoFactorEnabled Boolean       @default(false)
  accountStatus    AccountStatus @default(ACTIVE)

  // Social Media Links
  twitterHandle   String?
  instagramHandle String?
  facebookProfile String?
  linkedInProfile String?

  // Loyalty Programs
  loyaltyPrograms Json?
  travelMemberIds Json?

  // OPT: Removed totalTripsPlanned/totalTripsCompleted -- derivable via _count on TravelPlan
  countriesVisited     String[]
  favoriteDestinations String[]

  // Metadata
  accountDeactivatedAt DateTime? @db.Timestamptz(3)
  deactivationReason   String?

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nationality])
  @@index([accountStatus])
  @@map("profiles")
}

model TravelPlan {
  id          String  @id @default(cuid())
  title       String
  destination String
  description String?

  startDate DateTime @db.Timestamptz(3)
  endDate   DateTime @db.Timestamptz(3)
  budget    Float?

  // RENAMED: travelers → numberOfTravelers (more explicit, consistent with
  // TravelPackageBooking.numberOfTravelers throughout the codebase)
  numberOfTravelers Int @default(1)

  // NEW: preferred travel style for this specific trip
  // Drives AI recommendations and vendor suggestions
  travelStyle TravelStyle?

  // NEW: currency this travel plan is budgeted in
  // Allows multi-currency support across bookings
  currency String @default("USD")

  itinerary       Json?
  recommendations Json?
  interests       String[]

  status TravelPlanStatus @default(PLANNING)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  experiences           TravelExperience[]
  accommodations        AccommodationBooking[]
  transportServices     TransportationBooking[]
  shoppingVisits        ShoppingVisit[]
  travelPackageBookings TravelPackageBooking[]
  experienceBookings    ExperienceBooking[]

  @@index([userId])
  @@index([travelStyle])
  @@map("travel_plans")
}

// ==================== VENDOR MANAGEMENT ====================

enum VendorType {
  ACCOMMODATION_PROVIDER
  TRANSPORTATION_PROVIDER
  TRAVEL_AGENCY
  EXPERIENCE_PROVIDER
  SHOPPING_VENDOR
  RESTAURANT
  OTHER
}

enum VendorVerificationStatus {
  PENDING
  DOCUMENTS_SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
  SUSPENDED
}

enum VendorSubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum DocumentType {
  BUSINESS_LICENSE
  TAX_CERTIFICATE
  ID_PROOF
  INSURANCE
  OTHER
}

enum TeamMemberRole {
  ADMIN
  MANAGER
  EDITOR
  VIEWER
}

model Vendor {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName      String
  businessRegNumber String?      @unique
  taxId             String?
  vendorType        VendorType[]
  businessAddress   String
  businessPhone     String
  businessEmail     String
  website           String?
  description       String?
  logo              String?
  coverImage        String?

  verificationStatus VendorVerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedBy         String?
  verificationNotes  String?

  commissionRate     Float                  @default(10)
  subscriptionPlan   VendorSubscriptionPlan @default(FREE)
  subscriptionExpiry DateTime?
  autoRenew          Boolean                @default(true)

  // Cached aggregates — updated by rating.service.js whenever a VendorReview
  // is created, updated, or deleted for any of this vendor's listings.
  // overallRating = weighted avg of all non-hidden reviews across all listing types
  // totalReviews  = count of all non-hidden reviews
  overallRating Float @default(0)

  // NEW: total non-hidden review count across all listings
  totalReviews Int @default(0)

  payoutMethod     String?
  payoutDetails    Json?
  minimumPayout    Float   @default(100)
  balance          Float   @default(0)
  lifetimeEarnings Float   @default(0)

  isActive       Boolean   @default(true)
  isFeatured     Boolean   @default(false)
  featuredUntil  DateTime?
  maxListings    Int       @default(100)
  maxTeamMembers Int       @default(1)

  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?
  linkedInUrl  String?

  lastActivityAt   DateTime?
  suspensionReason String?
  suspendedUntil   DateTime?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  documents    VendorDocument[]
  teamMembers  VendorTeamMember[]
  reviews      VendorReview[]
  transactions Transaction[]
  payouts      Payout[]

  accommodations          Accommodation[]
  transportationProviders TransportationProvider[]
  travelPackages          TravelPackage[]
  experiences             VendorExperience[]
  retailStores            RetailStore[]

  @@index([vendorType])
  @@index([verificationStatus])
  @@index([overallRating])
  @@index([isFeatured])
  @@map("vendors")
}

model VendorDocument {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  documentType   DocumentType
  documentUrl    String
  documentNumber String?
  issueDate      DateTime?
  expiryDate     DateTime?
  issuingCountry String?

  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectionReason String?

  fileSize Int?
  mimeType String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([vendorId])
  @@index([documentType])
  @@map("vendor_documents")
}

model VendorTeamMember {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  role        TeamMemberRole
  permissions Json?

  isActive  Boolean   @default(true)
  invitedAt DateTime?
  joinedAt  DateTime?
  invitedBy String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([vendorId, userId])
  @@index([vendorId])
  @@index([userId])
  @@map("vendor_team_members")
}

model VendorReview {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  rating     Int       @default(5)
  title      String?
  comment    String?
  response   String?
  responseAt DateTime?

  isVerifiedPurchase Boolean @default(false)
  travelPlanId       String?
  bookingType        String?
  bookingId          String?

  helpfulCount Int     @default(0)
  reportCount  Int     @default(0)
  isHidden     Boolean @default(false)

  travelPackage      TravelPackage?    @relation(fields: [travelPackageId], references: [id])
  travelPackageId    String?
  vendorExperience   VendorExperience? @relation(fields: [vendorExperienceId], references: [id])
  vendorExperienceId String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([vendorId, userId, bookingId])
  @@index([vendorId])
  @@index([travelPackageId])
  @@index([vendorExperienceId])
  @@index([rating])
  @@index([createdAt])
  @@map("vendor_reviews")
}

model VendorApplication {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taxId          String?
  vendorTypes    VendorType[]
  documents      String[]
  additionalInfo String?

  status          ApplicationStatus @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([status])
  @@index([userId])
  @@map("vendor_applications")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== ACCOMMODATION MODELS ====================

model Accommodation {
  id          String  @id @default(cuid())
  name        String
  description String?

  address   String
  city      String
  country   String
  latitude  Float?
  longitude Float?

  phone   String?
  email   String?
  website String?

  starRating        Int?              @default(3)
  overallRating     Float?            @default(0)
  vendorId          String
  vendor            Vendor            @relation(fields: [vendorId], references: [id])
  accommodationType AccommodationType @default(HOTEL)
  priceCategory     PriceCategory     @default(MIDRANGE)

  amenities String[]
  images    String[]

  checkInTime        String?
  checkOutTime       String?
  policies           Json?
  cancellationPolicy String?

  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  rooms    AccommodationRoom[]
  services AccommodationService[]
  bookings AccommodationBooking[]

  @@unique([name, city, country])
  @@index([city])
  @@index([country])
  @@index([accommodationType])
  @@index([vendorId])
  @@index([isFeatured])
  @@map("accommodations")
}

model AccommodationRoom {
  id          String   @id @default(cuid())
  roomNumber  String
  roomType    RoomType
  description String?

  beds         Int     @default(1)
  maxOccupancy Int     @default(2)
  hasView      Boolean @default(false)
  hasBalcony   Boolean @default(false)
  floor        Int?

  roomAmenities String[]
  basePrice     Float
  isAvailable   Boolean  @default(true)

  accommodationId String
  accommodation   Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  bookings AccommodationBooking[]

  @@index([accommodationId])
  @@index([roomType])
  @@map("accommodation_rooms")
}

model AccommodationService {
  id          String          @id @default(cuid())
  name        String
  description String?
  category    ServiceCategory

  price       Float?
  isIncluded  Boolean @default(false)
  isAvailable Boolean @default(true)

  availableStartTime      String?
  availableEndTime        String?
  daysAvailable           String[]
  locationInAccommodation String?

  accommodationId String
  accommodation   Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([accommodationId])
  @@index([category])
  @@map("accommodation_services")
}

model AccommodationBooking {
  id String @id @default(cuid())

  checkInDate  DateTime @db.Timestamptz(3)
  checkOutDate DateTime @db.Timestamptz(3)
  // OPT: Removed totalNights -- derivable: ceil((checkOutDate - checkInDate) / 86400000)
  totalGuests  Int      @default(1)

  // OPT: Removed selectedRoomNumbers String[] -- duplicates the rooms relation
  roomType RoomType

  pricePerNight Float
  taxes         Float? @default(0)
  serviceFee    Float? @default(0)
  totalCost     Float

  guestName       String
  guestEmail      String
  guestPhone      String?
  specialRequests String?

  paymentStatus PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?
  transactionId String?

  bookingStatus      BookingStatus @default(PENDING)
  cancellationPolicy String?
  aiNotes            String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  travelPlanId    String
  travelPlan      TravelPlan    @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)
  accommodationId String
  accommodation   Accommodation @relation(fields: [accommodationId], references: [id])
  rooms           AccommodationRoom[]

  // OPT: Added back-relation to Transaction for consistency with other booking models
  transactions Transaction[]

  @@index([travelPlanId])
  @@index([accommodationId])
  @@index([bookingStatus])
  @@map("accommodation_bookings")
}

// ==================== TRANSPORTATION MODELS ====================

model TransportationProvider {
  id          String  @id @default(cuid())
  name        String
  description String?

  providerType  TransportationProviderType
  serviceArea   String[]
  contactNumber String?
  email         String?
  website       String?

  // NEW: physical base city and country of the provider
  // Enables location-based search alongside serviceArea[]
  city    String?
  country String?

  rating Float? @default(0)

  baseFare      Float?
  perKmRate     Float?
  perMinuteRate Float?

  isAvailable    Boolean @default(true)
  operatingHours Json?
  vehicleTypes   String[]

  isVerified    Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  vehicles TransportationVehicle[]
  bookings TransportationBooking[]

  @@index([providerType])
  @@index([name])
  @@index([city])
  @@index([country])
  @@index([vendorId])
  @@map("transportation_providers")
}

model TransportationVehicle {
  id            String @id @default(cuid())
  vehicleNumber String @unique // Internal fleet tracking number

  // NEW: public-facing license plate (separate from internal vehicleNumber)
  licensePlate String?

  vehicleType String

  make      String?
  model     String?
  year      Int?
  color     String?
  capacity  Int      @default(4)
  amenities String[] // Standard: AC, WiFi, USB charging, etc.

  // NEW: marketing/display features shown to customers on listing pages
  // Examples: "Luxury leather seats", "Entertainment system", "Baby seat available"
  features String[]

  driverName    String?
  driverContact String?
  driverRating  Float?  @default(0)

  // NEW: per-day and per-km pricing, separate from provider-level rates
  // Allows per-vehicle pricing overrides (e.g. luxury car vs economy car)
  pricePerDay Float?
  pricePerKm  Float?

  isAvailable     Boolean @default(true)
  currentLocation Json?

  providerId String
  provider   TransportationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  bookings TransportationBooking[]

  @@index([providerId])
  @@index([vehicleType])
  @@map("transportation_vehicles")
}

model TransportationBooking {
  id String @id @default(cuid())

  serviceType       TransportationServiceType
  pickupLocation    String
  dropoffLocation   String
  pickupTime        DateTime  @db.Timestamptz(3)
  estimatedArrival  DateTime? @db.Timestamptz(3)
  actualPickupTime  DateTime? @db.Timestamptz(3)
  actualDropoffTime DateTime? @db.Timestamptz(3)

  // OPT: Renamed to snapshot* -- historical record if vehicle/driver changes post-booking
  snapshotVehicleType   String?
  snapshotVehicleNumber String?
  snapshotDriverName    String?
  snapshotDriverContact String?

  numberOfPassengers Int     @default(1)
  specialRequests    String?

  estimatedFare Float?
  actualFare    Float?
  paymentMethod PaymentMethod?
  paymentStatus PaymentStatus  @default(PENDING)

  status TransportationStatus @default(BOOKED)

  aiNotes      String?
  alternatives Json?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  travelPlanId String
  travelPlan   TravelPlan @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)

  providerId String?
  provider   TransportationProvider? @relation(fields: [providerId], references: [id])

  vehicleId String?
  vehicle   TransportationVehicle? @relation(fields: [vehicleId], references: [id])

  @@index([travelPlanId])
  @@index([providerId])
  @@index([status])
  @@index([pickupTime])
  @@map("transportation_bookings")
}

// ==================== TRAVEL PACKAGE MODELS ====================

model TravelPackage {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  name         String
  description  String?

  // RENAMED: duration → durationDays (explicit unit, consistent with agent/dashboard)
  durationDays Int

  destinations String[]

  // finalPrice = basePrice - discount, compute at query time
  basePrice Float
  currency  String @default("USD")
  discount  Float? @default(0)

  includes  Json?
  excludes  Json?
  images    String[]
  video     String?
  itinerary Json?

  startDate     DateTime?
  endDate       DateTime?
  isRecurring   Boolean   @default(true)
  availableDays String[]

  minTravelers Int @default(1)
  maxTravelers Int @default(20)

  // NEW: cached average rating from VendorReview records linked to this package
  // Formula: AVG(VendorReview.rating WHERE travelPackageId = this.id AND isHidden = false)
  // Updated by: rating.service.js → recomputePackageRating(packageId)
  // Called by: any endpoint that creates/updates/deletes/hides a VendorReview
  //            for a travel package booking
  averageRating Float @default(0)

  // NEW: cached count of non-hidden reviews for display ("Based on 42 reviews")
  totalReviews Int @default(0)

  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  bookings TravelPackageBooking[]
  reviews  VendorReview[]

  @@index([vendorId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([averageRating])
  @@index([destinations])
  @@map("travel_packages")
}

model TravelPackageBooking {
  id           String        @id @default(cuid())
  packageId    String
  package      TravelPackage @relation(fields: [packageId], references: [id])
  travelPlanId String
  travelPlan   TravelPlan    @relation(fields: [travelPlanId], references: [id])

  bookingDate       DateTime @default(now()) @db.Timestamptz(3)
  startDate         DateTime @db.Timestamptz(3)
  endDate           DateTime @db.Timestamptz(3)
  numberOfTravelers Int      @default(1)

  basePrice   Float
  discount    Float? @default(0)
  finalAmount Float
  currency    String @default("USD")

  leadGuestName   String
  leadGuestEmail  String
  leadGuestPhone  String?
  specialRequests String?

  status        BookingStatus  @default(PENDING)
  paymentStatus PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?
  transactionId String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  transactions Transaction[]

  @@index([packageId])
  @@index([travelPlanId])
  @@index([status])
  @@map("travel_package_bookings")
}

// ==================== VENDOR EXPERIENCE MODELS ====================

model VendorExperience {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  name        String
  description String?
  category    ExperienceCategory

  location     String
  city         String
  country      String
  latitude     Float?
  longitude    Float?
  meetingPoint String?

  pricePerPerson Float
  currency       String @default("USD")
  childPrice     Float?
  groupDiscount  Json?

  durationHours Float
  startTime     String?
  endTime       String?

  minParticipants Int @default(1)
  maxParticipants Int @default(20)

  includes     String[]
  excludes     String[]
  whatToBring  String[]
  restrictions String?

  images String[]
  video  String?

  availableDays  String[]
  availableDates Json?
  blackoutDates  Json?

  // NEW: cached average rating from VendorReview records linked to this experience
  // Formula: AVG(VendorReview.rating WHERE vendorExperienceId = this.id AND isHidden = false)
  // Updated by: rating.service.js → recomputeExperienceRating(experienceId)
  // Called by: any endpoint that creates/updates/deletes/hides a VendorReview
  //            for an experience booking
  averageRating Float @default(0)

  // NEW: cached count of non-hidden reviews for display ("Based on 17 reviews")
  totalReviews Int @default(0)

  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  bookings ExperienceBooking[]
  reviews  VendorReview[]

  @@index([vendorId])
  @@index([city])
  @@index([category])
  @@index([averageRating])
  @@index([isFeatured])
  @@map("vendor_experiences")
}

model ExperienceBooking {
  id           String           @id @default(cuid())
  experienceId String
  experience   VendorExperience @relation(fields: [experienceId], references: [id])
  travelPlanId String
  travelPlan   TravelPlan       @relation(fields: [travelPlanId], references: [id])

  bookingDate          DateTime @default(now()) @db.Timestamptz(3)
  experienceDate       DateTime @db.Timestamptz(3)
  numberOfParticipants Int      @default(1)
  numberOfChildren     Int      @default(0)

  unitPrice   Float
  childPrice  Float?
  totalAmount Float
  currency    String @default("USD")

  leadGuestName   String
  leadGuestEmail  String
  leadGuestPhone  String?
  specialRequests String?

  status        BookingStatus  @default(PENDING)
  paymentStatus PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?
  transactionId String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  transactions Transaction[]

  @@index([experienceId])
  @@index([travelPlanId])
  @@index([experienceDate])
  @@map("experience_bookings")
}

// ==================== FINANCIAL MODELS ====================
//
// Transaction = money IN  (customer pays for a booking, platform receives funds)
// Payout      = money OUT (platform pays vendor, batching many transactions)
//
// Flow:  Booking --> Transaction(s) --> batched into --> Payout

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Transaction {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  amount    Float
  fee       Float  // Platform commission
  netAmount Float  // amount - fee = vendor earnings
  currency  String            @default("USD")
  status    TransactionStatus @default(PENDING)

  paymentMethod    PaymentMethod?
  paymentReference String?
  paymentDetails   Json?

  refundAmount Float?
  refundReason String?
  refundedAt   DateTime?

  description String?
  metadata    Json?

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  completedAt DateTime?

  // Which payout batch this transaction was included in
  payout   Payout? @relation(fields: [payoutId], references: [id])
  payoutId String?

  // OPT: Replaced bookingType String + bookingId String with typed FKs
  //      Gives referential integrity and removes stringly-typed polymorphism
  accommodationBookingId String?
  accommodationBooking   AccommodationBooking? @relation(fields: [accommodationBookingId], references: [id])

  travelPackageBookingId String?
  travelPackageBooking   TravelPackageBooking? @relation(fields: [travelPackageBookingId], references: [id])

  experienceBookingId String?
  experienceBooking   ExperienceBooking? @relation(fields: [experienceBookingId], references: [id])

  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

model Payout {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  amount    Float
  fee       Float? // Payout processing fee e.g. bank transfer fee
  netAmount Float  // amount - fee = what vendor actually receives
  currency  String       @default("USD")
  status    PayoutStatus @default(PENDING)

  payoutMethod  String // BANK_TRANSFER | PAYPAL | STRIPE
  payoutDetails Json?  // Destination details (store encrypted)

  processorResponse  Json?
  processorReference String?
  processedAt        DateTime?
  failureReason      String?

  // Bank details (store encrypted)
  bankName      String?
  accountNumber String?
  accountName   String?
  routingNumber String?
  swiftCode     String?

  requestedAt DateTime  @default(now()) @db.Timestamptz(3)
  completedAt DateTime?
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)

  // All transactions included in this payout batch
  transactions Transaction[]

  @@index([vendorId])
  @@index([status])
  @@index([requestedAt])
  @@map("payouts")
}

// ==================== SHOPPING MODELS ====================

model RetailStore {
  id          String  @id @default(cuid())
  name        String
  description String?

  storeType RetailStoreType @default(SHOPPING_MALL)
  address   String
  city      String
  country   String
  category  String?

  latitude  Float?
  longitude Float?

  phone   String?
  email   String?
  website String?

  openingHours Json?
  rating       Float?      @default(0)
  priceRange   PriceRange?
  products     Json?
  images       String[]

  isActive   Boolean @default(true)
  isVerified Boolean @default(false)

  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  visits ShoppingVisit[]

  @@index([city])
  @@index([country])
  @@index([storeType])
  @@index([vendorId])
  @@map("retail_stores")
}

model ShoppingVisit {
  id String @id @default(cuid())

  plannedDate     DateTime  @db.Timestamptz(3)
  actualVisitDate DateTime? @db.Timestamptz(3)
  duration        Int?

  purpose      String?
  plannedItems Json?
  status       ShoppingVisitStatus @default(PLANNED)

  aiNotes         String?
  recommendations Json?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  travelPlanId String
  travelPlan   TravelPlan @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)

  storeId String
  store   RetailStore @relation(fields: [storeId], references: [id])

  @@index([travelPlanId])
  @@index([storeId])
  @@index([plannedDate])
  @@map("shopping_visits")
}

// ==================== EXPERIENCE MODELS ====================

model TravelExperience {
  id          String  @id @default(cuid())
  title       String
  description String?

  date      DateTime           @db.Timestamptz(3)
  startTime String?
  endTime   String?
  location  String?
  cost      Float?             @default(0)
  category  ExperienceCategory @default(SIGHTSEEING)
  aiNotes   String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  travelPlanId String
  travelPlan   TravelPlan @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)

  @@index([travelPlanId])
  @@map("travel_experiences")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  isRevoked Boolean  @default(false)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  title   String
  message String?
  data    Json?

  isRead Boolean   @default(false)
  readAt DateTime? @db.Timestamptz(3)

  severity NotificationSeverity @default(INFO)
  icon     String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}


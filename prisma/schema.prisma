// prisma/schema.prisma
generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CORE MODELS ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String // Changed from Int to String
  password  String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Email verification
  emailVerified           Boolean   @default(false)
  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime? @db.Timestamptz(3)

  // Password reset
  resetPasswordToken  String?   @unique
  resetPasswordExpiry DateTime? @db.Timestamptz(3)

  // Relations
  travelPlans             TravelPlan[]
  refreshTokens           RefreshToken[]
  profile                 Profile?
  vendorApplications      VendorApplication[]
  vendor                  Vendor? // One-to-one with vendor
  accommodations          Accommodation[] // As vendor
  transportationProviders TransportationProvider[] // As vendor
  travelPackages          TravelPackage[] // As vendor
  vendorExperiences       VendorExperience[] // As vendor
  vendorReviews           VendorReview[] // Reviews given
  transactions            Transaction[] // As vendor
  vendorTeamMembers       VendorTeamMember[]

  @@map("users")
}

model Profile {
  id String @id @default(cuid())

  // Personal Information
  dateOfBirth    DateTime? @db.Timestamptz(3)
  gender         String? // Use Gender enum
  nationality    String?
  profilePicture String?
  bio            String?

  // Contact Information
  address                  String?
  city                     String?
  country                  String?
  postalCode               String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Preferences
  language String  @default("en")
  currency String  @default("USD")
  timezone String?

  // Travel Preferences
  dietaryRestrictions  String[]
  mobilityNeeds        String[]
  accessibilityNeeds   String[]
  preferredTravelStyle String? // Use TravelStyle enum
  travelCompanionPref  String? // Use TravelCompanion enum
  interests            String[]

  // Communication Preferences
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  smsNotifications   Boolean @default(false)
  marketingEmails    Boolean @default(false)

  // Account Details
  emailVerified    Boolean @default(false)
  twoFactorEnabled Boolean @default(false)
  accountStatus    String  @default("ACTIVE") // Use AccountStatus enum

  // Social Media Links
  twitterHandle   String?
  instagramHandle String?
  facebookProfile String?
  linkedInProfile String?

  // Loyalty Programs
  loyaltyPrograms Json?
  travelMemberIds Json?

  // Statistics
  totalTripsPlanned    Int      @default(0)
  totalTripsCompleted  Int      @default(0)
  countriesVisited     String[]
  favoriteDestinations String[]

  // Metadata
  lastLogin            DateTime? @db.Timestamptz(3)
  lastActive           DateTime? @db.Timestamptz(3)
  accountDeactivatedAt DateTime? @db.Timestamptz(3)
  deactivationReason   String?

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nationality])
  @@index([accountStatus])
  @@map("profiles")
}

model TravelPlan {
  id          String  @id @default(cuid())
  title       String
  destination String
  description String?

  // Travel details
  startDate DateTime @db.Timestamptz(3)
  endDate   DateTime @db.Timestamptz(3)
  budget    Float?
  travelers Int      @default(1)

  // AI-generated content
  itinerary       Json?
  recommendations Json?

  // User preferences
  interests String[]

  // Status
  status TravelPlanStatus @default(PLANNING)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Travel components
  experiences           TravelExperience[]
  accommodations        AccommodationBooking[]
  transportServices     TransportationBooking[]
  shoppingVisits        ShoppingVisit[]
  travelPackageBookings TravelPackageBooking[]
  experienceBookings    ExperienceBooking[]

  @@index([userId])
  @@map("travel_plans")
}

// ==================== VENDOR MANAGEMENT ====================

enum VendorType {
  ACCOMMODATION_PROVIDER
  TRANSPORTATION_PROVIDER
  TRAVEL_AGENCY
  EXPERIENCE_PROVIDER
  SHOPPING_VENDOR
  RESTAURANT
  OTHER
}

enum VendorVerificationStatus {
  PENDING
  DOCUMENTS_SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
  SUSPENDED
}

enum VendorSubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

model Vendor {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business Information
  businessName      String
  businessRegNumber String?      @unique
  taxId             String?
  vendorType        VendorType[]
  businessAddress   String
  businessPhone     String
  businessEmail     String
  website           String?
  description       String?
  logo              String?
  coverImage        String?

  // Verification
  verificationStatus VendorVerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedBy         String? // SuperAdmin ID
  verificationNotes  String?

  // Commission & Fees
  commissionRate     Float                  @default(10) // Platform commission percentage
  subscriptionPlan   VendorSubscriptionPlan @default(FREE)
  subscriptionExpiry DateTime?
  autoRenew          Boolean                @default(true)

  // Ratings & Reviews
  overallRating Float @default(0)
  totalReviews  Int   @default(0)

  // Payment & Payout
  payoutMethod     String? // 'BANK_TRANSFER', 'PAYPAL', 'STRIPE'
  payoutDetails    Json? // Store encrypted payout details
  minimumPayout    Float   @default(100)
  balance          Float   @default(0)
  lifetimeEarnings Float   @default(0)

  // Settings
  isActive       Boolean   @default(true)
  isFeatured     Boolean   @default(false)
  featuredUntil  DateTime?
  maxListings    Int       @default(100)
  maxTeamMembers Int       @default(1)

  // Social Media
  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?
  linkedInUrl  String?

  // Metadata
  lastLoginAt      DateTime?
  lastActivityAt   DateTime?
  suspensionReason String?
  suspendedUntil   DateTime?

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  documents    VendorDocument[]
  teamMembers  VendorTeamMember[]
  reviews      VendorReview[]
  transactions Transaction[]
  payouts      Payout[]

  // Service listings
  accommodations          Accommodation[]
  transportationProviders TransportationProvider[]
  travelPackages          TravelPackage[]
  experiences             VendorExperience[]
  retailStores            RetailStore[]

  @@index([vendorType])
  @@index([verificationStatus])
  @@index([overallRating])
  @@index([isFeatured])
  @@map("vendors")
}

model VendorDocument {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  documentType   String // 'BUSINESS_LICENSE', 'TAX_CERT', 'ID_PROOF', 'INSURANCE'
  documentUrl    String
  documentNumber String?
  issueDate      DateTime?
  expiryDate     DateTime?
  issuingCountry String?

  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectionReason String?

  // Metadata
  fileSize Int?
  mimeType String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([vendorId])
  @@index([documentType])
  @@map("vendor_documents")
}

model VendorTeamMember {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  role        String // 'ADMIN', 'MANAGER', 'EDITOR', 'VIEWER'
  permissions Json? // Granular permissions

  isActive  Boolean   @default(true)
  invitedAt DateTime?
  joinedAt  DateTime?
  invitedBy String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([vendorId, userId])
  @@index([vendorId])
  @@index([userId])
  @@map("vendor_team_members")
}

model VendorReview {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  rating     Int       @default(5) // 1-5
  title      String?
  comment    String?
  response   String? // Vendor response to review
  responseAt DateTime?

  // Metadata
  isVerifiedPurchase Boolean @default(false)
  travelPlanId       String?
  bookingType        String? // 'ACCOMMODATION', 'TRANSPORTATION', 'PACKAGE'
  bookingId          String?

  // Helpfulness
  helpfulCount Int     @default(0)
  reportCount  Int     @default(0)
  isHidden     Boolean @default(false)

  createdAt          DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime          @updatedAt @db.Timestamptz(3)
  travelPackage      TravelPackage?    @relation(fields: [travelPackageId], references: [id])
  travelPackageId    String?
  vendorExperience   VendorExperience? @relation(fields: [vendorExperienceId], references: [id])
  vendorExperienceId String?

  @@unique([vendorId, userId])
  @@index([vendorId])
  @@index([rating])
  @@index([createdAt])
  @@map("vendor_reviews")
}

model VendorApplication {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business details
  businessName    String
  businessAddress String
  businessPhone   String
  businessEmail   String
  taxId           String?
  vendorTypes     VendorType[]

  // Documents
  documents      String[] // URLs to uploaded documents
  additionalInfo String?

  // Status
  status          ApplicationStatus @default(PENDING)
  reviewedBy      String? // SuperAdmin ID who reviewed
  reviewedAt      DateTime?
  rejectionReason String?
  approvedTypes   VendorType[] // Which vendor types were approved

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([status])
  @@index([userId])
  @@map("vendor_applications")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== ACCOMMODATION MODELS ====================

model Accommodation {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  // Location
  address   String
  city      String
  country   String
  latitude  Float?
  longitude Float?

  // Contact
  phone   String?
  email   String?
  website String?

  // Details
  starRating        Int?              @default(3)
  overallRating     Float?            @default(0)
  vendorId          String
  vendor            Vendor            @relation(fields: [vendorId], references: [id])
  accommodationType AccommodationType @default(HOTEL)
  priceCategory     PriceCategory     @default(MIDRANGE)

  // Amenities
  amenities String[]
  images    String[]

  // Policies
  checkInTime        String? // Format: "14:00:00"
  checkOutTime       String? // Format: "11:00:00"
  policies           Json?
  cancellationPolicy String?

  // Status
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?

  // Stats
  totalBookings Int @default(0)
  totalReviews  Int @default(0)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  rooms    AccommodationRoom[]
  services AccommodationService[]
  bookings AccommodationBooking[]
  user     User?                  @relation(fields: [userId], references: [id])
  userId   String?

  @@index([city])
  @@index([country])
  @@index([accommodationType])
  @@index([vendorId])
  @@index([isFeatured])
  @@map("accommodations")
}

model AccommodationRoom {
  id          String   @id @default(cuid())
  roomNumber  String
  roomType    RoomType
  description String?

  // Room details
  beds         Int     @default(1)
  maxOccupancy Int     @default(2)
  hasView      Boolean @default(false)
  hasBalcony   Boolean @default(false)
  floor        Int?

  // Amenities
  roomAmenities String[]
  basePrice     Float
  isAvailable   Boolean  @default(true)

  // Relations
  accommodationId String
  accommodation   Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3) // UTC timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(3) // UTC timestamp

  // Booking relation (fix: this should be many-to-many or one-to-many, not one-to-one)
  bookings AccommodationBooking[] // Changed from single relation to array

  @@index([accommodationId])
  @@index([roomType])
  @@map("accommodation_rooms")
}

model AccommodationService {
  id          String          @id @default(cuid())
  name        String
  description String?
  category    ServiceCategory

  // Service details
  price       Float?
  isIncluded  Boolean @default(false)
  isAvailable Boolean @default(true)

  // Timing - Store as strings since they're recurring daily times
  availableStartTime String? // Format: "09:00:00"
  availableEndTime   String? // Format: "17:00:00"
  daysAvailable      String[] // Days of week: ["MONDAY", "TUESDAY", etc.]

  // Location
  locationInAccommodation String?

  // Relations
  accommodationId String
  accommodation   Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3) // UTC timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(3) // UTC timestamp

  @@index([accommodationId])
  @@index([category])
  @@map("accommodation_services")
}

model AccommodationBooking {
  id String @id @default(cuid())

  // Booking details - Store as UTC timestamps
  checkInDate  DateTime @db.Timestamptz(3) // UTC timestamp
  checkOutDate DateTime @db.Timestamptz(3) // UTC timestamp
  totalNights  Int
  totalGuests  Int      @default(1)

  // Room details
  roomType            RoomType
  selectedRoomNumbers String[]

  // Pricing
  pricePerNight Float
  taxes         Float? @default(0)
  serviceFee    Float? @default(0)
  totalCost     Float

  // Guest information
  guestName       String
  guestEmail      String
  guestPhone      String?
  specialRequests String?

  // Payment
  paymentStatus PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?
  transactionId String?

  // Status
  bookingStatus      BookingStatus @default(PENDING)
  cancellationPolicy String?

  // AI-generated
  aiNotes String?

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3) // UTC timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(3) // UTC timestamp

  // Relations
  travelPlanId String
  travelPlan   TravelPlan @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)

  accommodationId String
  accommodation   Accommodation @relation(fields: [accommodationId], references: [id])

  rooms AccommodationRoom[] // Many-to-many relation through join table would be better, but this works

  // Validation: Ensure checkOutDate is after checkInDate (handle in app logic)
  @@index([travelPlanId])
  @@index([accommodationId])
  @@index([bookingStatus])
  @@map("accommodation_bookings")
}

// ==================== TRANSPORTATION MODELS ====================

model TransportationProvider {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  // Provider details
  providerType  TransportationProviderType
  serviceArea   String[]
  contactNumber String?
  email         String?
  website       String?

  // Ratings
  rating     Float? @default(0)
  totalTrips Int?   @default(0)

  // Pricing
  baseFare      Float?
  perKmRate     Float?
  perMinuteRate Float?

  // Availability
  isAvailable    Boolean @default(true)
  operatingHours Json?

  // Vehicles
  vehicleTypes String[]

  // Status
  isVerified    Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?

  // Stats
  totalBookings Int @default(0)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  vehicles TransportationVehicle[]
  bookings TransportationBooking[]
  user     User?                   @relation(fields: [userId], references: [id])
  userId   String?

  @@index([providerType])
  @@index([name])
  @@index([vendorId])
  @@map("transportation_providers")
}

model TransportationVehicle {
  id            String @id @default(cuid())
  vehicleNumber String @unique
  vehicleType   String

  // Vehicle details
  make     String?
  model    String?
  year     Int?
  color    String?
  capacity Int     @default(4)

  // Amenities
  amenities String[]

  // Driver info
  driverName    String?
  driverContact String?
  driverRating  Float?  @default(0)

  // Status
  isAvailable     Boolean @default(true)
  currentLocation Json? // Store as JSON with lat/long and timestamp

  // Relations
  providerId String
  provider   TransportationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3) // UTC timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(3) // UTC timestamp

  // Relations
  bookings TransportationBooking[]

  @@index([providerId])
  @@index([vehicleType])
  @@map("transportation_vehicles")
}

model TransportationBooking {
  id String @id @default(cuid())

  // Booking details - Store as UTC timestamps
  serviceType       TransportationServiceType
  pickupLocation    String
  dropoffLocation   String
  pickupTime        DateTime                  @db.Timestamptz(3) // UTC timestamp
  estimatedArrival  DateTime?                 @db.Timestamptz(3) // UTC timestamp
  actualPickupTime  DateTime?                 @db.Timestamptz(3) // UTC timestamp
  actualDropoffTime DateTime?                 @db.Timestamptz(3) // UTC timestamp

  // Vehicle and driver
  vehicleType   String?
  vehicleNumber String?
  driverName    String?
  driverContact String?

  // Passenger info
  numberOfPassengers Int     @default(1)
  specialRequests    String?

  // Pricing
  estimatedFare Float?
  actualFare    Float?
  paymentMethod PaymentMethod?
  isPaid        Boolean        @default(false)
  paymentStatus PaymentStatus  @default(PENDING)

  // Status
  status TransportationStatus @default(BOOKED)

  // AI-generated
  aiNotes      String?
  alternatives Json?

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3) // UTC timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(3) // UTC timestamp

  // Relations
  travelPlanId String
  travelPlan   TravelPlan @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)

  providerId String?
  provider   TransportationProvider? @relation(fields: [providerId], references: [id])

  vehicleId String?
  vehicle   TransportationVehicle? @relation(fields: [vehicleId], references: [id])

  // Validation: Ensure estimatedArrival is after pickupTime (handle in app logic)
  @@index([travelPlanId])
  @@index([providerId])
  @@index([status])
  @@index([pickupTime])
  @@map("transportation_bookings")
}

// ==================== TRAVEL PACKAGE MODELS ====================

model TravelPackage {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  name         String
  description  String?
  duration     Int // Duration in days
  destinations String[] // Array of destinations

  // Pricing
  basePrice  Float
  currency   String @default("USD")
  discount   Float? @default(0)
  finalPrice Float?

  // Inclusions
  includes Json? // What's included in the package
  excludes Json? // What's not included

  // Media
  images String[]
  video  String?

  // Itinerary
  itinerary Json? // Day-wise itinerary

  // Availability
  startDate     DateTime?
  endDate       DateTime?
  isRecurring   Boolean   @default(true)
  availableDays String[] // Days of week when available

  // Capacity
  minTravelers Int @default(1)
  maxTravelers Int @default(20)

  // Status
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?

  // Stats
  totalBookings Int   @default(0)
  averageRating Float @default(0)
  totalReviews  Int   @default(0)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  bookings TravelPackageBooking[]
  reviews  VendorReview[] // Reviews for this package
  user     User?                  @relation(fields: [userId], references: [id])
  userId   String?

  @@index([vendorId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([destinations])
  @@map("travel_packages")
}

model TravelPackageBooking {
  id           String        @id @default(cuid())
  packageId    String
  package      TravelPackage @relation(fields: [packageId], references: [id])
  travelPlanId String
  travelPlan   TravelPlan    @relation(fields: [travelPlanId], references: [id])

  bookingDate       DateTime @default(now()) @db.Timestamptz(3)
  startDate         DateTime @db.Timestamptz(3)
  endDate           DateTime @db.Timestamptz(3)
  numberOfTravelers Int      @default(1)

  // Pricing
  basePrice   Float
  discount    Float? @default(0)
  finalAmount Float
  currency    String @default("USD")

  // Guest information
  leadGuestName   String
  leadGuestEmail  String
  leadGuestPhone  String?
  specialRequests String?

  // Status
  status        BookingStatus  @default(PENDING)
  paymentStatus PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?
  transactionId String?

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  transactions Transaction[]

  @@index([packageId])
  @@index([travelPlanId])
  @@index([status])
  @@map("travel_package_bookings")
}

// ==================== VENDOR EXPERIENCE MODELS ====================

model VendorExperience {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  name        String
  description String?
  category    ExperienceCategory

  // Location
  location     String
  city         String
  country      String
  latitude     Float?
  longitude    Float?
  meetingPoint String?

  // Pricing
  pricePerPerson Float
  currency       String @default("USD")
  childPrice     Float?
  groupDiscount  Json? // Discount for groups

  // Duration
  durationHours Float
  startTime     String?
  endTime       String?

  // Capacity
  minParticipants Int @default(1)
  maxParticipants Int @default(20)

  // Inclusions
  includes     String[]
  excludes     String[]
  whatToBring  String[]
  restrictions String?

  // Media
  images String[]
  video  String?

  // Availability
  availableDays  String[] // Days of week
  availableDates Json? // Specific available dates
  blackoutDates  Json? // Unavailable dates

  // Status
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?

  // Stats
  totalBookings Int   @default(0)
  averageRating Float @default(0)
  totalReviews  Int   @default(0)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  bookings ExperienceBooking[]
  reviews  VendorReview[] // Reviews for this experience
  user     User?               @relation(fields: [userId], references: [id])
  userId   String?

  @@index([vendorId])
  @@index([city])
  @@index([category])
  @@index([isFeatured])
  @@map("vendor_experiences")
}

model ExperienceBooking {
  id           String           @id @default(cuid())
  experienceId String
  experience   VendorExperience @relation(fields: [experienceId], references: [id])
  travelPlanId String
  travelPlan   TravelPlan       @relation(fields: [travelPlanId], references: [id])

  bookingDate          DateTime @default(now()) @db.Timestamptz(3)
  experienceDate       DateTime @db.Timestamptz(3)
  numberOfParticipants Int      @default(1)
  numberOfChildren     Int      @default(0)

  // Pricing
  unitPrice   Float
  childPrice  Float?
  totalAmount Float
  currency    String @default("USD")

  // Guest information
  leadGuestName   String
  leadGuestEmail  String
  leadGuestPhone  String?
  specialRequests String?

  // Status
  status        BookingStatus  @default(PENDING)
  paymentStatus PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?
  transactionId String?

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  transactions Transaction[]

  @@index([experienceId])
  @@index([travelPlanId])
  @@index([experienceDate])
  @@map("experience_bookings")
}

// ==================== FINANCIAL MODELS ====================

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Transaction {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  amount    Float
  fee       Float // Platform fee
  netAmount Float // Amount after fee
  currency  String            @default("USD")
  status    TransactionStatus @default(PENDING)

  // Related entities
  bookingType String // 'ACCOMMODATION', 'TRANSPORTATION', 'PACKAGE', 'EXPERIENCE'
  bookingId   String

  // Payment
  paymentMethod    PaymentMethod?
  paymentReference String?
  paymentDetails   Json?

  // Refund
  refundAmount Float?
  refundReason String?
  refundedAt   DateTime?

  // Metadata
  description String?
  metadata    Json?

  // Timestamps
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  completedAt DateTime?

  // Relations
  payout                 Payout?               @relation(fields: [payoutId], references: [id])
  user                   User?                 @relation(fields: [userId], references: [id])
  userId                 String?
  travelPackageBooking   TravelPackageBooking? @relation(fields: [travelPackageBookingId], references: [id])
  travelPackageBookingId String?
  experienceBooking      ExperienceBooking?    @relation(fields: [experienceBookingId], references: [id])
  experienceBookingId    String?
  payoutId               String?

  @@index([vendorId])
  @@index([status])
  @@index([bookingId])
  @@index([createdAt])
  @@map("transactions")
}

model Payout {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  amount    Float
  fee       Float? // Payout processing fee
  netAmount Float
  currency  String       @default("USD")
  status    PayoutStatus @default(PENDING)

  // Payout method
  payoutMethod  String // 'BANK_TRANSFER', 'PAYPAL', 'STRIPE'
  payoutDetails Json? // Store payout destination details

  // Transactions included
  transactionIds String[]

  // Processing
  processorResponse  Json?
  processorReference String?
  processedAt        DateTime?
  failureReason      String?

  // Bank details (encrypted)
  bankName      String?
  accountNumber String?
  accountName   String?
  routingNumber String?
  swiftCode     String?

  // Timestamps
  requestedAt DateTime  @default(now()) @db.Timestamptz(3)
  completedAt DateTime?
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)

  // Relations
  transactions Transaction[]

  @@index([vendorId])
  @@index([status])
  @@index([requestedAt])
  @@map("payouts")
}

// ==================== SHOPPING MODELS ====================

model RetailStore {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Store details
  storeType RetailStoreType @default(SHOPPING_MALL)
  address   String
  city      String
  country   String
  category  String?

  // Location coordinates - ADD THESE FIELDS
  latitude  Float?   // Add this
  longitude Float?   // Add this

  // Contact
  phone   String?
  email   String?
  website String?

  // Store information
  openingHours Json?
  rating       Float?      @default(0)
  priceRange   PriceRange?

  // Products
  products Json?

  // Images
  images String[]

  // Status
  isActive   Boolean @default(true)
  isVerified Boolean @default(false)
  vendorId   String? // Optional - stores can be independent or vendor-owned
  vendor     Vendor? @relation(fields: [vendorId], references: [id])

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  visits ShoppingVisit[]

  @@index([city])
  @@index([country])
  @@index([storeType])
  @@index([vendorId])
  @@map("retail_stores")
}

model ShoppingVisit {
  id String @id @default(cuid())

  // Visit details - Store as UTC timestamps
  plannedDate     DateTime  @db.Timestamptz(3) // UTC timestamp
  actualVisitDate DateTime? @db.Timestamptz(3) // UTC timestamp
  duration        Int? // Duration in minutes

  // Shopping intent
  purpose      String?
  plannedItems Json?

  // Status
  status ShoppingVisitStatus @default(PLANNED)

  // AI-generated
  aiNotes         String?
  recommendations Json?

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3) // UTC timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(3) // UTC timestamp

  // Relations
  travelPlanId String
  travelPlan   TravelPlan @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)

  storeId String
  store   RetailStore @relation(fields: [storeId], references: [id])

  @@index([travelPlanId])
  @@index([storeId])
  @@index([plannedDate])
  @@map("shopping_visits")
}

// ==================== EXPERIENCE MODELS ====================

model TravelExperience {
  id          String  @id @default(cuid())
  title       String
  description String?

  // Experience details - Store date as UTC timestamp
  date      DateTime @db.Timestamptz(3) // UTC timestamp
  startTime String? // Format: "14:30:00" - since it's a recurring time within the date
  endTime   String? // Format: "16:30:00"
  location  String?
  cost      Float?   @default(0)

  // Category
  category ExperienceCategory @default(SIGHTSEEING)

  // AI-generated
  aiNotes String?

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3) // UTC timestamp
  updatedAt DateTime @updatedAt @db.Timestamptz(3) // UTC timestamp

  // Relations
  travelPlanId String
  travelPlan   TravelPlan @relation(fields: [travelPlanId], references: [id], onDelete: Cascade)

  @@index([travelPlanId])
  @@map("travel_experiences")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @db.Timestamptz(3) // UTC timestamp
  createdAt DateTime @default(now()) @db.Timestamptz(3) // UTC timestamp
  isRevoked Boolean  @default(false)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

